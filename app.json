{
  "expo": {
    "name": "Logistics",
    "slug": "mobile-logistics",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "logistics",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#22c55e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.logistics.mobile",
      "config": {
        "googleMapsApiKey": "AIzaSyD7lNP6tvJ2stkFyRvGxzsq1PBt64YUQGU"
      },
      "infoPlist": {
        "NSLocationAlwaysAndWhenInUseUsageDescription": "La app necesita tu ubicación para el tracking de envíos.",
        "NSLocationWhenInUseUsageDescription": "La app necesita tu ubicación para el tracking de envíos.",
        "NSCameraUsageDescription": "Necesitamos la cámara para tomar fotos de entrega y recibos.",
        "NSPhotoLibraryUsageDescription": "Necesitamos acceso a tus fotos para adjuntar imágenes."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#22c55e"
      },
  "package": "com.logistics.mobile",
  "permissions": [
    "ACCESS_COARSE_LOCATION",
    "ACCESS_FINE_LOCATION",
    "ACCESS_BACKGROUND_LOCATION",
    "CAMERA",
    "READ_EXTERNAL_STORAGE",
    "WRITE_EXTERNAL_STORAGE",
    "android.permission.ACCESS_COARSE_LOCATION",
    "android.permission.ACCESS_FINE_LOCATION",
    "android.permission.CAMERA",
    "android.permission.RECORD_AUDIO"
  ],
  "config": {
    "googleMaps": {
      "apiKey": "AIzaSyD7lNP6tvJ2stkFyRvGxzsq1PBt64YUQGU"
    }
  }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "La app necesita tu ubicación para el tracking de envíos."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Necesitamos la cámara para tomar fotos de entrega y recibos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#22c55e"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9c5cde74-7a5e-4d3b-99d5-ad5731f76773"
      }
    }
  }
}
